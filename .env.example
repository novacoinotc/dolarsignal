# ── REQUERIDO ─────────────────────────────────────────────────
# Connection string de Neon Postgres.
# En Vercel usa el string POOLED (host con sufijo "-pooler"); en Railway sirve cualquiera de los dos.
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── OPCIONAL ──────────────────────────────────────────────────
# Alertas por Telegram: crea un bot con @BotFather y obtén tu chat_id con @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Token gratuito de Banxico SIE (https://www.banxico.org.mx/SieAPIRest/) para el tipo de cambio FIX
BANXICO_TOKEN=

# Bitso RFQ — SOLO LECTURA del precio real institucional (nunca ejecuta compras).
# Solo el worker (Railway) las necesita; el dashboard de Vercel lee el precio desde la BD.
BITSO_API_KEY=
BITSO_API_SECRET=
RFQ_QUOTE_MXN=1000000          # tamaño de la cotización de referencia (MXN)
RFQ_POLL_MS=120000             # cada cuánto pedir cotización (ms)

# Puerto del dashboard local / Railway (Railway lo inyecta automáticamente)
PORT=8420

# Proxy de salida (si Yahoo/Google bloquean la IP del datacenter de Railway).
# NODE_USE_ENV_PROXY=1 hace que fetch() de Node respete HTTPS_PROXY/NO_PROXY.
# NODE_USE_ENV_PROXY=1
# HTTPS_PROXY=http://usuario:password@host:puerto
# NO_PROXY=api.bitso.com,api.telegram.org,*.neon.tech
